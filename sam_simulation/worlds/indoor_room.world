<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="indoor_room">
    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>

    <!-- A simple wall to look at -->
    <model name="wall">
      <static>true</static>
      <pose>2 0 1 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.2 4 2</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>0.2 4 2</size></box></geometry></visual>
      </link>
    </model>
  </world>
</sdf>
